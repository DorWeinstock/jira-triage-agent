JIRA_URL=https://jira.devtools.intel.com
JIRA_EMAIL=your-service-account@intel.com
JIRA_TOKEN=your_jira_api_token

JIRA_PROJECT=GAUDISW
PROCESSED_LABEL=triage-agent-done

# Comma-separated Jira usernames of your team members
TEAM_MEMBERS=dweinsto,davidtal,gennadyd

POLL_INTERVAL=5m

# vLLM endpoint (OpenAI-compatible)
